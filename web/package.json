{
  "name": "svelte-manage-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "基于 Svelte 5 + TypeScript + Vite 7 + Tailwind CSS 4 构建的管理后台框架",
  "author": "zhoolg <https://github.com/zhoolg>",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhoolg/svelte-manage-web.git"
  },
  "keywords": [
    "svelte",
    "typescript",
    "vite",
    "tailwindcss",
    "admin",
    "framework",
    "crud",
    "dashboard"
  ],
  "scripts": {
    "dev": "vite",
    "server:dev": "mvn -f ../server/pom.xml spring-boot:run -Dspring-boot.run.profiles=dev",
    "server:build": "mvn -f ../server/pom.xml package",
    "server:check": "mvn -f ../server/pom.xml test",
    "build": "npm run check && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsgo -p tsconfig.node.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rename-project": "node scripts/rename-project.cjs"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "bits-ui": "^2.16.3",
    "lucide-svelte": "^0.563.0",
    "write-excel-file": "^4.0.7"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.11.0",
    "@typescript/native-preview": "7.0.0-dev.20260515.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
  }
}
