# 生产配置模板。复制为 jar 同级目录下的 application-prod.yml 后再按实际环境填写。

server:
  port: 8080
  servlet:
    encoding:
      charset: UTF-8
      force: true

spring:
  application:
    name: svelte-manage-web-server
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: ${MYSQL_URL}
    username: ${MYSQL_USERNAME}
    password: ${MYSQL_PASSWORD}
    hikari:
      maximum-pool-size: 20
      minimum-idle: 5
      connection-timeout: 30000
      validation-timeout: 5000
      idle-timeout: 300000
      max-lifetime: 600000
      keepalive-time: 300000
  sql:
    init:
      mode: never
      encoding: UTF-8
  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}
      timeout: 500ms
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 20MB
  ai:
    model:
      chat: ${AI_MODEL_PROVIDER:none}
      image: none
      embedding: none
      moderation: none
      audio:
        speech: none
        transcription: none
    chat:
      client:
        enabled: ${AI_SPRING_AI_ENABLED:false}
    openai:
      api-key: ${OPENAI_API_KEY:}
      base-url: ${OPENAI_BASE_URL:https://api.openai.com}
      chat:
        enabled: ${AI_OPENAI_ENABLED:false}
        options:
          model: ${OPENAI_MODEL:gpt-4o-mini}
          temperature: 0.2
      embedding:
        enabled: false
    anthropic:
      api-key: ${ANTHROPIC_API_KEY:}
      chat:
        enabled: ${AI_ANTHROPIC_ENABLED:false}
        options:
          model: ${ANTHROPIC_MODEL:claude-3-5-sonnet-latest}
          temperature: 0.2
          max-tokens: 4096

app:
  crypto:
    private-key-path: ${APP_RSA_PRIVATE_KEY_PATH:secrets/rsa-private.pem}
    generate-ephemeral-key: false
  cache:
    redis-enabled: true
  auth:
    cookie:
      name: SESSION
      secure: true
      same-site: Strict
    session-ttl-minutes: 120
    rate-limit:
      max-per-minute: 30
    passkey:
      rp-id: ${PASSKEY_RP_ID}
      rp-name: Svelte Manage Web
      origins: ${PASSKEY_ORIGINS}
      challenge-ttl-minutes: 5
    session:
      use-redis: true
    captcha:
      enabled: true
      length: 4
      ttl-seconds: 120
      max-entries: 2000
    seed-password: ${ADMIN_SEED_PASSWORD:}
  cors:
    allowed-origins: ${APP_ALLOWED_ORIGINS}
  upload:
    dir: uploads
    public-path: /uploads
  web:
    wechat-login-enabled: false
  ai:
    credentials:
      secret: ${AI_CREDENTIAL_SECRET}
    spring-ai:
      enabled: ${AI_SPRING_AI_ENABLED:false}
      max-output-chars: 12000

management:
  endpoints:
    web:
      exposure:
        include: health,info

springdoc:
  api-docs:
    enabled: false
  swagger-ui:
    enabled: false
